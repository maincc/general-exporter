#  general-exporter 配置文件
# 支持的 target 类型: url, docker, custom, remote
# 复制此文件为 config.yaml 并修改后使用

server:
  port: 8080
  metrics_path: /metrics
  max_concurrent: 10             # 采集最大并发数
  expose_runtime_metrics: true   # 是否暴露 go_* / process_* 指标（默认 true）

defaults:
  interval: 30s       # 采集间隔
  timeout: 10s        # 单次请求超时
  # global_labels:    # 可选，全局标签注入所有指标（url/docker/custom，remote 除外）
  #   cluster: "prod-1"
  #   region: "cn-shanghai"

# target 级别可关闭全局标签：
# - name: "internal_api"
#   type: url
#   url: "http://internal:8080/health"
#   use_global_labels: false  # 默认 true，设为 false 则该 target 的全局 label 值为空

targets:
  # ==================== 前端服务 ====================
  - name: "frontend_main"
    type: url
    url: "https://example.com"
    method: GET
    expected_status: 200
    interval: 15s
    labels:
      env: "prod"
      tier: "frontend"

  # ==================== Docker 容器 ====================
  - name: "all_containers"
    type: docker
    mode: all           # all = 所有容器
    interval: 30s
    labels:
      env: "prod"
      tier: "docker"

  # 指定容器示例（取消注释即可使用）
  # - name: "key_containers"
  #   type: docker
  #   mode: filter
  #   names:
  #     - "nginx"
  #     - "redis"
  #     - "mysql"
  #   interval: 15s
  #   labels:
  #     env: "prod"
  #     tier: "docker"

  # ==================== 自定义脚本 ====================
  # - name: "skywell_node"
  #   type: custom
  #   script: "/app/scripts/skywell-stats.sh"
  #   labels:
  #     env: "prod"
  #     tier: "node"
  #
  #   脚本输出格式（每行: 指标名 数值）：
  #   echo "skywell_cpu_percent 42.5"
  #   echo "skywell_memory_bytes 512000000"
  #   echo "skywell_connections 15"

  # ==================== 后端服务 ====================
  - name: "backend_api"
    type: url
    url: "http://localhost:8081/health"
    method: GET
    expected_status: 200
    interval: 15s
    labels:
      env: "prod"
      tier: "backend"

  - name: "backend_grafana"
    type: url
    url: "http://localhost:3000/api/health"
    method: GET
    expected_status: 200
    interval: 30s
    labels:
      env: "prod"
      tier: "backend"

  # ==================== 远程 Metrics 代理 ====================
  # - name: "remote_node_exporter"
  #   type: remote
  #   remote:
  #     url: "http://localhost:9100/metrics"
  #     # headers:         # 可选，自定义请求头
  #     #   Authorization: "Bearer xxx"
  #
  # - name: "remote_blackbox"
  #   type: remote
  #   remote:
  #     url: "http://localhost:9115/metrics"
